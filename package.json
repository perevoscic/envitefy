{
  "name": "envitefy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-single.js",
    "dev:turbo": "node scripts/dev-single.js --turbopack",
    "build": "node scripts/next-build.js",
    "build:turbo": "node scripts/next-build.js --turbo",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "clean": "node -e \"const fs=require('fs');for(const d of ['.next','.next-dev']){try{fs.rmSync(d,{recursive:true,force:true});console.log('removed '+d)}catch(e){console.error(e);process.exit(1)}}\"",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "icons": "node scripts/generate-icons.js",
    "favicon": "node scripts/generate-favicon.js",
    "db:init": "node scripts/init-db.js",
    "blob:backfill-pathnames": "node scripts/backfill-discovery-blob-pathnames.mjs",
    "blob:input-blobs-report": "node scripts/report-event-history-input-blobs-shape.mjs",
    "blob:delete-broken-input-blobs": "node scripts/delete-broken-event-history-input-blobs.mjs",
    "blob:transport-event-media": "node --experimental-strip-types scripts/transport-event-media-to-blob.ts",
    "purge:user-event-data": "node --experimental-strip-types scripts/purge-user-event-data.ts",
    "signup:templates": "node scripts/generate-signup-templates-openai.mjs",
    "signup:templates:nana": "node scripts/generate-signup-templates-google.mjs --profile=nana",
    "signup:templates:openrouter": "node scripts/generate-signup-templates-openrouter.mjs",
    "signup:templates:openrouter:nana": "node scripts/generate-signup-templates-openrouter.mjs --profile=nana",
    "birthday:themes": "node scripts/generate-birthday-theme-images.mjs",
    "birthday:extract-elements": "node scripts/extract-theme-elements.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.887.0",
    "@google-cloud/aiplatform": "^5.11.0",
    "@google-cloud/storage": "^7.12.1",
    "@google-cloud/vertexai": "^1.10.0",
    "@google-cloud/vision": "^5.3.3",
    "@napi-rs/canvas": "^0.1.95",
    "@prisma/client": "^6.15.0",
    "@supabase/supabase-js": "^2.95.3",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/blob": "^2.3.2",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.2",
    "chrono-node": "^2.8.4",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.5",
    "googleapis": "^156.0.0",
    "ical-generator": "^9.0.0",
    "jose": "^6.0.13",
    "lucide-react": "^0.473.0",
    "framer-motion": "^12.38.0",
    "multer": "^2.0.2",
    "next": "15.5.9",
    "next-auth": "^4.24.7",
    "next-connect": "^1.0.0",
    "node-qpdf": "^1.0.3",
    "nodemailer": "^6.10.1",
    "openai": "^4.76.3",
    "pdfjs-dist": "^5.5.207",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.4",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4",
    "@types/cookie": "^0.6.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.59.0",
    "png-to-ico": "^3.0.1",
    "prisma": "^6.15.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
